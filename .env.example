# Copy this file to .env and fill in the paths for your environment.
# .env is gitignored -- never commit it.
#
# WHY THIS EXISTS
# ---------------
# The ShuttleSet data (clips, shuttle npy, mmpose npy) is large and lives in
# different locations depending on where you are working:
#
#   - Local dev machine: data may not exist at all (tests use fake data)
#   - HPC (engelbart):   data lives under /scratch/comp320a/...
#
# Rather than passing --clips-dir, --shuttle-npy-dir, etc. every time you run
# pipeline.data_access, set them here once and they are picked up
# automatically. Shell exports always take precedence over this file, so you
# can still override on the fly if needed.
#
# HOW TO USE
# ----------
# 1. Copy this file:   cp .env.example .env
# 2. Fill in the paths below for your environment
# 3. Run normally:     python3.11 -m pipeline.data_access --summary
#
# POST-PHASE-2 LAYOUT NOTES
# -------------------------
# - BST_CLIPS_DIR still holds a nested tree: {split}/{Top,Bottom}_{stroke}/*.mp4.
# - BST_SHUTTLE_NPY_DIR is flat after Phase 2.2: {clip_stem}.npy directly.
# - BST_MMPOSE_NPY_DIR is flat after Phase 2.1: {clip_stem}_joints.npy and
#   {clip_stem}_pos.npy directly. Leave blank until pose extraction has run.
# - BST_CLIPS_CSV points at clips_master.csv (the post-Phase-2 source of
#   truth for split + taxonomy class per clip). Defaults to
#   <repo_root>/notebooks/clips_master.csv when unset.
#
# HPC PATHS (engelbart, example)
# ------------------------------
# BST_CLIPS_DIR=/scratch/comp320a/ShuttleSet/clips
# BST_SHUTTLE_NPY_DIR=/scratch/comp320a/ShuttleSet/shuttle_npy_flat
# BST_MMPOSE_NPY_DIR=/scratch/comp320a/ShuttleSet_data_merged_25/dataset_npy_between_2_hits_with_max_limits_flat
# BST_CLIPS_CSV=/home/<username>/badminton_stroke_classification/notebooks/clips_master.csv

BST_CLIPS_DIR=
BST_SHUTTLE_NPY_DIR=
BST_MMPOSE_NPY_DIR=
BST_CLIPS_CSV=
