# Exclude version control - large and not needed in the image
.git

# Exclude Python cache - gets regenerated
__pycache__
**/__pycache__
*.pyc
*.pyo
.pytest_cache/

# Exclude secrets
.env

# Exclude virtual envs
.venv
venv/

# Exclude frontend build artefacts and deps - these are built inside the container
frontend/node_modules/
frontend/dist/

# Exclude data and runtime uploads - both are mounted as volumes at runtime
data/
uploads/

# Exclude notebooks and scratch notes - not needed for serving
notebooks/
scratch/
